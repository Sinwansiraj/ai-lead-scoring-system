# Copy to .env and adjust for your environment
# All settings have sensible defaults — only override what you need

# ── Paths ──────────────────────────────────────────────────────────────
MODEL_DIR=models
MODEL_FILENAME=lead_scorer.joblib

# ── Data ───────────────────────────────────────────────────────────────
N_SAMPLES=5000
CONVERSION_RATE=0.12
RANDOM_SEED=42
TEST_SIZE=0.2

# ── Model ──────────────────────────────────────────────────────────────
XGB_N_ESTIMATORS=200
XGB_MAX_DEPTH=6
XGB_LEARNING_RATE=0.05
XGB_SUBSAMPLE=0.8
XGB_COLSAMPLE_BYTREE=0.8

# ── API ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_WORKERS=1
LOG_LEVEL=INFO

# ── Scoring thresholds ─────────────────────────────────────────────────
HOT_THRESHOLD=80
WARM_THRESHOLD=50
